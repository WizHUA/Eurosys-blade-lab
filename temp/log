# ChaosBlade工具配置
chaosblade:
  command: "blade"
  timeout: 60

# 异常类型定义
fault_types:
  # CPU相关故障
  cpu_fullload:
    type: "cpu"
    subtype: "fullload"
    description: "CPU满负载故障"
    default_params:
      cpu-percent: 70
      timeout: 60
    param_ranges:
      cpu-percent: [50, 100]
      timeout: [30, 300]

  # RAM内存负载故障  
  mem_load_ram:
    type: "mem"
    subtype: "load"
    description: "RAM内存负载故障"
    default_params:
      mode: "ram"
      mem-percent: 70
      timeout: 60
    param_ranges:
      mem-percent: [50, 95]
      timeout: [30, 300]

  # Buffer内存负载故障
  mem_load_buffer:
    type: "mem"
    subtype: "load"
    description: "Buffer内存负载故障"
    default_params:
      mode: "buffer"
      mem-percent: 70
      timeout: 60
    param_ranges:
      mem-percent: [50, 95]
      timeout: [30, 300]

  # Stack内存负载故障
  mem_load_stack:
    type: "mem"
    subtype: "load"
    description: "Stack内存负载故障"
    default_params:
      mode: "stack"
      mem-percent: 70
      timeout: 60
    param_ranges:
      mem-percent: [50, 95]
      timeout: [30, 300]

  # 网络丢包故障
  network_loss:
    type: "network"
    subtype: "loss"
    description: "网络包丢失故障"
    default_params:
      percent: "50"
      interface: "ens33"
      timeout: 60
    param_ranges:
      percent: ["1", "90"]
      timeout: [30, 300]

  # 磁盘读写负载故障
  disk_burn:
    type: "disk"
    subtype: "burn"
    description: "磁盘读写负载故障"
    default_params:
      read: true
      write: true
      path: "/tmp"
      size: "100"
      timeout: 60
    param_ranges:
      size: ["50", "500"]
      timeout: [30, 300]

  # 磁盘填充故障
  disk_fill:
    type: "disk"
    subtype: "fill"
    description: "磁盘空间填充故障"
    default_params:
      path: "/tmp"
      size: "100"
      percent: "90"
      timeout: 60
    param_ranges:
      size: ["50", "1000"]
      percent: ["50", "90"]
      timeout: [30, 300]

# 故障注入计划
chaos_plans:
  empty_plan:
    description: "空计划"
    faults: []

  formaltest:
    description: "7个单独异常 + 21个组合异常 (约55min)"
